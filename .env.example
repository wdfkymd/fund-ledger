# SQLite database (relative to project root)
DATABASE_URL="file:./dev.db"

# Required: random secret for JWT sessions (e.g. openssl rand -hex 32)
AUTH_SECRET="change-me-to-a-long-random-string"

# Optional: reserved for future cron-style jobs

# HTTP 部署（无 TLS）时设 1，否则生产 Cookie Secure 会导致浏览器不存会话
AUTH_TRUST_HTTP=1
# 1=允许公开注册；个人实例建议 0
ALLOW_REGISTER=0
# 可选强制 Cookie Secure：0|1（覆盖上面逻辑）
# COOKIE_SECURE=0
